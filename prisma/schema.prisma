// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String   // Hash de la contraseña
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones - acciones creadas por este usuario
  createdProducts      Product[]      @relation("ProductCreatedBy")
  updatedProducts      Product[]      @relation("ProductUpdatedBy")
  createdClients       Client[]       @relation("ClientCreatedBy")
  updatedClients       Client[]       @relation("ClientUpdatedBy")
  createdObras         Obra[]         @relation("ObraCreatedBy")
  updatedObras         Obra[]         @relation("ObraUpdatedBy")
  createdRentals       Rental[]       @relation("RentalCreatedBy")
  updatedRentals       Rental[]       @relation("RentalUpdatedBy")
  createdStockMovements StockMovement[] @relation("StockMovementCreatedBy")
  
  @@index([username])
}

model Product {
  id              String   @id @default(uuid())
  name            String
  description     String?
  stockTotal      Int      @default(0)
  stockActual     Int      @default(0)
  price           Float
  notes           String?
  lowStockThreshold Int?   @default(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Auditoría
  createdById     String?
  updatedById     String?
  createdBy       User?    @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?    @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  // Relaciones
  stockAddHistory StockAddHistory[]
  rentalItems     RentalItem[]
  stockMovements   StockMovement[]
  
  @@index([createdById])
  @@index([updatedById])
}

model StockAddHistory {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  date      DateTime @default(now())
  notes     String?
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([productId])
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Auditoría
  createdById String?
  updatedById String?
  createdBy   User?  @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?  @relation("ClientUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  // Relaciones
  obras     Obra[]
  rentals   Rental[]
  
  @@index([createdById])
  @@index([updatedById])
}

model Obra {
  id          String   @id @default(uuid())
  clientId    String
  name        String
  description String?
  address     String?
  totalPrice  Float    @default(0)
  pagado      Float    @default(0)
  resto       Float    @default(0)
  status      String   @default("active") // active, completed, paused
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Auditoría
  createdById String?
  updatedById String?
  createdBy   User?   @relation("ObraCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("ObraUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  // Relaciones
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rentals     Rental[]
  stockMovements StockMovement[]
  
  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
}

model Rental {
  id            String   @id @default(uuid())
  workId         String
  clientId       String
  totalPrice     Float    @default(0)
  pagado         Float    @default(0)
  resto          Float    @default(0)
  returnDate     DateTime
  status         String   @default("sin presupuestar") // sin presupuestar, presupuestado, iniciado, finalizado
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Auditoría
  createdById   String?
  updatedById   String?
  createdBy     User?    @relation("RentalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?    @relation("RentalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  // Relaciones
  obra           Obra     @relation(fields: [workId], references: [id], onDelete: Cascade)
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items          RentalItem[]
  paymentHistory PaymentHistory[]
  stockMovements StockMovement[]
  
  @@index([workId])
  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
}

model RentalItem {
  id          String   @id @default(uuid())
  rentalId    String
  productId   String
  quantity    Int
  unitPrice   Float
  dailyPrice  Float
  totalPrice  Float
  addedDate   DateTime
  
  // Relaciones
  rental      Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([rentalId])
  @@index([productId])
}

model PaymentHistory {
  id        String   @id @default(uuid())
  rentalId  String
  amount    Float
  date      DateTime @default(now())
  periodFrom DateTime
  periodTo   DateTime
  notes     String?
  
  // Relaciones
  rental    Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@index([rentalId])
}

model StockMovement {
  id          String   @id @default(uuid())
  obraId      String
  rentalId    String?
  productId   String
  quantity    Int
  type        String   // salida, entrada
  reason      String
  timestamp   DateTime @default(now())
  
  // Auditoría
  createdById String?
  createdBy   User?   @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  
  // Relaciones
  obra        Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  rental      Rental?  @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([obraId])
  @@index([rentalId])
  @@index([productId])
  @@index([timestamp])
  @@index([createdById])
}

